@page
@model SvsWebApp.Pages.IndexModel
<div class="card">
    <h2>Save Player</h2>
    @if (!string.IsNullOrWhiteSpace(Model.Message)) { <div class="msg">@Model.Message</div> }
    @if (!string.IsNullOrWhiteSpace(Model.Error)) { <div class="err">@Model.Error</div> }
    <form method="post" enctype="multipart/form-data">
        <div class="grid">
            <div><label>Player Name</label><input asp-for="Input.PlayerName" /></div>
            <div><label>Total Power</label><input asp-for="Input.TotalPower" /></div>
            <div><label>Total Kills</label><input asp-for="Input.TotalKills" /></div>
            <div><label>Tech Power</label><input asp-for="Input.TechPower" /></div>
            <div><label>Hero Power</label><input asp-for="Input.HeroPower" /></div>
            <div><label>Troop Power</label><input asp-for="Input.TroopPower" /></div>
            <div><label>Structure Power</label><input asp-for="Input.StructurePower" /></div>
            <div><label>Mod Vehicle Power</label><input asp-for="Input.ModVehiclePower" /></div>
            <div style="grid-column:1/-1"><label>Notes</label><textarea asp-for="Input.Notes"></textarea></div>
            <div style="grid-column:1/-1"><label>Screenshot</label><input asp-for="Input.Screenshot" type="file" /></div>
        </div>
        <br />
        <button type="submit">Calculate and Save</button>
    </form>
</div>

@if (Model.LastSaved != null)
{
<div class="card">
    <h3>Last Saved Result: @Model.LastSaved.PlayerName</h3>
    <div class="grid">
        <div>Danger Score: <strong>@Model.LastSaved.DangerScore.ToString("F2")</strong></div>
        <div>Threat: <span class="badge">@Model.LastSaved.ThreatLabel</span></div>
        <div>Combat Density: @Model.LastSaved.CombatDensity.ToString("F4")</div>
        <div>Kill Efficiency: @Model.LastSaved.KillEfficiency.ToString("F4")</div>
        <div>Tech Readiness: @Model.LastSaved.TechReadiness.ToString("P2")</div>
        <div>Hero Lethality: @Model.LastSaved.HeroLethality.ToString("P2")</div>
    </div>
</div>
}
