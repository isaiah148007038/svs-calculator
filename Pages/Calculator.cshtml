@page
@model CalculatorModel
@{
    ViewData["Title"] = "Calculator";
}

<div class="grid">
    <section class="card">
        <h1>SVS Player Calculator</h1>
        <p>Version 2 saves players, supports screenshot uploads, and lets your team compare accounts later.</p>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="error">@Model.ErrorMessage</div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="success">@Model.SuccessMessage</div>
        }

        <form method="post" enctype="multipart/form-data">
            <div class="form-grid">
                <div>
                    <label asp-for="Input.PlayerName">Player Name</label>
                    <input asp-for="Input.PlayerName" placeholder="Optional" />
                </div>
                <div>
                    <label asp-for="SubmittedBy">Submitted By</label>
                    <input asp-for="SubmittedBy" placeholder="R4 / R5 name" />
                </div>
                <div>
                    <label asp-for="Input.TotalPower">Total Power</label>
                    <input asp-for="Input.TotalPower" placeholder="159.5M" />
                </div>
                <div>
                    <label asp-for="Input.TotalKills">Total Kills</label>
                    <input asp-for="Input.TotalKills" placeholder="2.4M" />
                </div>
                <div>
                    <label asp-for="Input.TechPower">Tech Power</label>
                    <input asp-for="Input.TechPower" placeholder="35M" />
                </div>
                <div>
                    <label asp-for="Input.HeroPower">Hero Power</label>
                    <input asp-for="Input.HeroPower" placeholder="22M" />
                </div>
                <div>
                    <label asp-for="Input.TroopPower">Troop Power</label>
                    <input asp-for="Input.TroopPower" placeholder="75M" />
                </div>
                <div>
                    <label asp-for="Input.StructurePower">Structure Power</label>
                    <input asp-for="Input.StructurePower" placeholder="18M" />
                </div>
                <div>
                    <label asp-for="Input.ModVehiclePower">Mod Vehicle Power</label>
                    <input asp-for="Input.ModVehiclePower" placeholder="9M or blank" />
                </div>
                <div>
                    <label asp-for="Screenshot">Screenshot Upload</label>
                    <input asp-for="Screenshot" type="file" accept=".jpg,.jpeg,.png,.webp" />
                </div>
            </div>

            <div class="stack-top">
                <label asp-for="Notes">Notes</label>
                <textarea asp-for="Notes" rows="4" placeholder="Any comments about the player or screenshot"></textarea>
            </div>

            <div class="check-row">
                <input asp-for="SaveEntry" type="checkbox" />
                <label asp-for="SaveEntry">Save this player entry for compare/admin pages</label>
            </div>

            <div class="button-row">
                <button type="submit">Calculate + Save</button>
                <a class="button secondary" href="/Calculator">Clear</a>
            </div>
        </form>
    </section>

    <section class="card">
        <h2>Results</h2>

        @if (Model.Result is not null)
        {
            <div class="result-head">
                <div class="player-name">@(string.IsNullOrWhiteSpace(Model.Result.PlayerName) ? "Unnamed Player" : Model.Result.PlayerName)</div>
                <div class="pill">@Model.Result.ThreatLabel threat</div>
            </div>

            <div class="results">
                <div><span>Combat Density</span><strong>@Model.Result.CombatDensity.ToString("F4")</strong></div>
                <div><span>Kill Efficiency</span><strong>@Model.Result.KillEfficiency.ToString("F4")</strong></div>
                <div><span>Tech Readiness</span><strong>@Model.Result.TechReadiness.ToString("P2")</strong></div>
                <div><span>Hero Lethality</span><strong>@Model.Result.HeroLethality.ToString("P2")</strong></div>
                <div><span>Troop Bias</span><strong>@Model.Result.TroopBias.ToString("P2")</strong></div>
                <div><span>Fake Power</span><strong>@Model.Result.FakePower.ToString("P2")</strong></div>
                <div><span>SVS Danger Score</span><strong>@Model.Result.DangerScore.ToString("F2")</strong></div>
                <div><span>Threat Label</span><strong>@Model.Result.ThreatLabel</strong></div>
            </div>
        }
        else
        {
            <p class="muted">No result yet. Enter player values and press Calculate + Save.</p>
        }
    </section>
</div>
