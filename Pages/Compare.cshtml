@page
@model SvsWebApp.Pages.CompareModel
<div class="card">
    <h2>Saved Players</h2>
    <table>
        <thead><tr><th>Name</th><th>Danger</th><th>Threat</th><th>Created</th><th>Notes</th></tr></thead>
        <tbody>
        @foreach (var e in Model.Entries)
        {
            <tr>
                <td>@e.PlayerName</td>
                <td>@e.DangerScore.ToString("F2")</td>
                <td>@e.ThreatLabel</td>
                <td>@e.CreatedUtc.ToString("u")</td>
                <td>@e.Notes</td>
            </tr>
        }
        </tbody>
    </table>
</div>
