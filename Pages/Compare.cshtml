@page
@model CompareModel
@{
    ViewData["Title"] = "Compare Players";
}

<div class="card">
    <div class="section-head">
        <div>
            <h1>Compare Saved Players</h1>
            <p class="muted">Sorted by highest SVS Danger Score first.</p>
        </div>
        <div class="button-row no-top">
            <a class="button secondary" href="/Calculator">Add Player</a>
        </div>
    </div>

    @if (!Model.Entries.Any())
    {
        <p class="muted">No saved players yet.</p>
    }
    else
    {
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Player</th>
                        <th>Submitted By</th>
                        <th>Danger</th>
                        <th>Threat</th>
                        <th>Total Power</th>
                        <th>Total Kills</th>
                        <th>Combat Density</th>
                        <th>Fake Power</th>
                        <th>Screenshot</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var entry in Model.Entries)
                {
                    <tr>
                        <td>@(string.IsNullOrWhiteSpace(entry.Result.PlayerName) ? "Unnamed" : entry.Result.PlayerName)</td>
                        <td>@(string.IsNullOrWhiteSpace(entry.SubmittedBy) ? "-" : entry.SubmittedBy)</td>
                        <td>@entry.Result.DangerScore.ToString("F2")</td>
                        <td>@entry.Result.ThreatLabel</td>
                        <td>@entry.Input.TotalPower</td>
                        <td>@entry.Input.TotalKills</td>
                        <td>@entry.Result.CombatDensity.ToString("F4")</td>
                        <td>@entry.Result.FakePower.ToString("P2")</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(entry.ScreenshotPath))
                            {
                                <a href="@entry.ScreenshotPath" target="_blank">Open</a>
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
