@page
@model SvsWebApp.Pages.AdminModel
<div class="card">
    <h2>Admin</h2>
    @if (!string.IsNullOrWhiteSpace(Model.Message)) { <div class="msg">@Model.Message</div> }
    @if (!string.IsNullOrWhiteSpace(Model.Error)) { <div class="err">@Model.Error</div> }
    <form method="post">
        <button asp-page-handler="Backup" type="submit" class="secondary">Create Backup</button>
        <button asp-page-handler="Restore" type="submit" class="secondary">Restore Latest Backup</button>
        <button asp-page-handler="Export" type="submit">Export CSV</button>
    </form>
</div>

<div class="card">
    <h3>Players</h3>
    <table>
        <thead><tr><th>Name</th><th>Danger</th><th>Status</th><th>Action</th></tr></thead>
        <tbody>
        @foreach (var e in Model.Entries)
        {
            <tr>
                <td>@e.PlayerName</td>
                <td>@e.DangerScore.ToString("F2")</td>
                <td>@(e.IsDeleted ? "Deleted" : "Active")</td>
                <td>
                    <form method="post" style="display:inline; width:auto;">
                        <input type="hidden" name="id" value="@e.Id" />
                        @if (!e.IsDeleted)
                        {
                            <button asp-page-handler="Delete" type="submit" class="danger">Soft Delete</button>
                        }
                        else
                        {
                            <button asp-page-handler="RestoreOne" type="submit" class="secondary">Restore</button>
                        }
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<div class="card">
    <h3>Audit Log</h3>
    <table>
        <thead><tr><th>Time</th><th>Action</th><th>Role</th><th>IP</th><th>Details</th></tr></thead>
        <tbody>
        @foreach (var l in Model.Logs)
        {
            <tr><td>@l.CreatedUtc.ToString("u")</td><td>@l.Action</td><td>@l.ActorRole</td><td>@l.ActorIp</td><td>@l.Details</td></tr>
        }
        </tbody>
    </table>
</div>
